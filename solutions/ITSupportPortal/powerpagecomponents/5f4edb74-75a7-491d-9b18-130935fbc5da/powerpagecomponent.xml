5.47 7.97l-1.06 1.06L7 11.62l5.09-5.09-1.06-1.06z\" /&gt;\n          &lt;/svg&gt;\n        &lt;/div&gt;\n        &lt;p class=\"feature-title\"&gt;Request access&lt;/p&gt;\n        &lt;p class=\"feature-desc\"&gt;Request software or shared drive access.&lt;/p&gt;\n        &lt;a href=\"#\" class=\"feature-link\"&gt;Request →&lt;/a&gt;\n      &lt;/div&gt;\n      &lt;div class=\"feature-card\"&gt;\n        &lt;div class=\"feature-icon feature-icon--purple\"&gt;\n          &lt;svg viewBox=\"0 0 16 16\"&gt;\n            &lt;path d=\"M8 1a3.5 3.5 0 100 7 3.5 3.5 0 000-7zm-5 9.5a1 1 0 011-1h8a1 1 0 011 1V14H3v-3.5z\" /&gt;\n          &lt;/svg&gt;\n        &lt;/div&gt;\n        &lt;p class=\"feature-title\"&gt;New employee setup&lt;/p&gt;\n        &lt;p class=\"feature-desc\"&gt;Onboarding checklist — accounts and equipment.&lt;/p&gt;\n        &lt;a href=\"#\" class=\"feature-link\"&gt;Start →&lt;/a&gt;\n      &lt;/div&gt;\n      &lt;div class=\"feature-card\"&gt;\n        &lt;div class=\"feature-icon feature-icon--navy\"&gt;\n          &lt;svg viewBox=\"0 0 16 16\"&gt;\n            &lt;path d=\"M2 4.5A1.5 1.5 0 013.5 3h9A1.5 1.5 0 0114 4.5v7a1.5 1.5 0 01-1.5 1.5h-9A1.5 1.5 0 012 11.5v-7zm1.5-.5a.5.5 0 00-.5.5v.5h10v-.5a.5.5 0 00-.5-.5h-9zM3 6.5v5a.5.5 0 00.5.5h9a.5.5 0 00.5-.5v-5H3zm2 1.5h6v1H5V8zm0 2h4v1H5v-1z\" /&gt;\n          &lt;/svg&gt;\n        &lt;/div&gt;\n        &lt;p class=\"feature-title\"&gt;IT policies&lt;/p&gt;\n        &lt;p class=\"feature-desc\"&gt;Acceptable use and security standards.&lt;/p&gt;\n        &lt;a href=\"#\" class=\"feature-link\"&gt;View →&lt;/a&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=\"card\"&gt;\n      &lt;div class=\"card-head\"&gt;\n        &lt;h3&gt;My recent tickets&lt;/h3&gt;\n        &lt;a href=\"my-tickets.html\" class=\"card-link\"&gt;View all →&lt;/a&gt;\n      &lt;/div&gt;\n      &lt;div class=\"ticket-row\"&gt;\n        &lt;div class=\"ticket-dot ticket-dot--prog\"&gt;&lt;/div&gt;\n        &lt;div class=\"ticket-info\"&gt;\n          &lt;p class=\"ticket-title\"&gt;Laptop screen flickering on startup&lt;/p&gt;\n          &lt;p class=\"ticket-meta\"&gt;TKT-0041 &amp;middot; Hardware &amp;middot; 2h ago&lt;/p&gt;\n        &lt;/div&gt;\n        &lt;span class=\"badge badge--prog\"&gt;In progress&lt;/span&gt;\n      &lt;/div&gt;\n      &lt;div class=\"ticket-row\"&gt;\n        &lt;div class=\"ticket-dot ticket-dot--new\"&gt;&lt;/div&gt;\n        &lt;div class=\"ticket-info\"&gt;\n          &lt;p class=\"ticket-title\"&gt;Cannot access shared drive — Finance&lt;/p&gt;\n          &lt;p class=\"ticket-meta\"&gt;TKT-0039 &amp;middot; Access &amp;middot; 1d ago&lt;/p&gt;\n        &lt;/div&gt;\n        &lt;span class=\"badge badge--high\"&gt;High&lt;/span&gt;\n      &lt;/div&gt;\n      &lt;div class=\"ticket-row\"&gt;\n        &lt;div class=\"ticket-dot ticket-dot--done\"&gt;&lt;/div&gt;\n        &lt;div class=\"ticket-info\"&gt;\n          &lt;p class=\"ticket-title\"&gt;Outlook not syncing calendar with Teams&lt;/p&gt;\n          &lt;p class=\"ticket-meta\"&gt;TKT-0035 &amp;middot; Software &amp;middot; 3d ago&lt;/p&gt;\n        &lt;/div&gt;\n        &lt;span class=\"badge badge--done\"&gt;Resolved&lt;/span&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n  &lt;/main&gt;\n&lt;/div&gt;\n{%else%}\n\n&lt;script&gt;\n  window.location.href = \"/signin\";\n&lt;/script&gt;\n\n{%endif%}\n\n&lt;script&gt;\n    document.getElementById(\"sbmtbtn\").addEventListener(\"click\", function () {\n      window.location.href = \"/submit\";\n  });\n&lt;/script&gt;\n&lt;div class=\"row sectionBlockLayout text-start\" style=\"display: flex; flex-wrap: wrap; margin: 0px; min-height: auto; padding: 8px;\"&gt;\n  &lt;div class=\"container\" style=\"padding: 0px; display: flex; flex-wrap: wrap;\"&gt;&lt;div class=\"col-lg-12 columnBlockLayout\" style=\"flex-grow: 1; display: flex; flex-direction: column; min-width: 250px;\"&gt;&lt;/div&gt;&lt;/div&gt;\n&lt;/div&gt;"
