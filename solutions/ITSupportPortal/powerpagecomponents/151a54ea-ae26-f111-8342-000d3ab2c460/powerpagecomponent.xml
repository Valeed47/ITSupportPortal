  "copy": "{% fetchxml alltickets %}\n&lt;fetch&gt;\n  &lt;entity name=\"it_request\"&gt;\n    &lt;attribute name=\"it_requestid\" /&gt;\n    &lt;attribute name=\"it_affecteddevice\" /&gt;\n    &lt;attribute name=\"it_category\" /&gt;\n    &lt;attribute name=\"it_categoryname\" /&gt;\n    &lt;attribute name=\"it_priority\" /&gt;\n    &lt;attribute name=\"it_priorityname\" /&gt;\n    &lt;attribute name=\"it_requeststatus\" /&gt;\n    &lt;attribute name=\"it_requeststatusname\" /&gt;\n    &lt;attribute name=\"it_startdate\" /&gt;\n    &lt;attribute name=\"it_newcolumn\" /&gt;\n    &lt;attribute name=\"it_tickettitle\" /&gt;\n    &lt;attribute name=\"it_ticketcreatedby\" /&gt;\n    &lt;attribute name=\"createdby\" /&gt;\n    &lt;filter type=\"and\"&gt;\n      &lt;condition attribute=\"statecode\" operator=\"eq\" value=\"0\" /&gt;\n    &lt;/filter&gt;\n  &lt;/entity&gt;\n&lt;/fetch&gt;\n{% endfetchxml %} {% fetchxml resolvedtickets %}\n&lt;fetch&gt;\n  &lt;entity name=\"it_request\"&gt;\n    &lt;attribute name=\"it_requestid\" /&gt;\n    &lt;attribute name=\"it_affecteddevice\" /&gt;\n    &lt;attribute name=\"it_category\" /&gt;\n    &lt;attribute name=\"it_categoryname\" /&gt;\n    &lt;attribute name=\"it_priority\" /&gt;\n    &lt;attribute name=\"it_priorityname\" /&gt;\n    &lt;attribute name=\"it_requeststatus\" /&gt;\n    &lt;attribute name=\"it_requeststatusname\" /&gt;\n    &lt;attribute name=\"it_startdate\" /&gt;\n    &lt;attribute name=\"it_newcolumn\" /&gt;\n    &lt;attribute name=\"it_tickettitle\" /&gt;\n    &lt;attribute name=\"it_ticketcreatedby\" /&gt;\n    &lt;filter type=\"and\"&gt;\n      &lt;condition attribute=\"statecode\" operator=\"eq\" value=\"0\" /&gt;\n      &lt;condition attribute=\"it_requeststatus\" operator=\"eq\" value=\"1\" /&gt;\n    &lt;/filter&gt;\n  &lt;/entity&gt;\n&lt;/fetch&gt;\n{% endfetchxml %} {% fetchxml inprogresstickets %}\n&lt;fetch&gt;\n  &lt;entity name=\"it_request\"&gt;\n    &lt;attribute name=\"it_requestid\" /&gt;\n    &lt;attribute name=\"it_affecteddevice\" /&gt;\n    &lt;attribute name=\"it_category\" /&gt;\n    &lt;attribute name=\"it_categoryname\" /&gt;\n    &lt;attribute name=\"it_priority\" /&gt;\n    &lt;attribute name=\"it_priorityname\" /&gt;\n    &lt;attribute name=\"it_requeststatus\" /&gt;\n    &lt;attribute name=\"it_requeststatusname\" /&gt;\n    &lt;attribute name=\"it_startdate\" /&gt;\n    &lt;attribute name=\"it_newcolumn\" /&gt;\n    &lt;attribute name=\"it_tickettitle\" /&gt;\n    &lt;attribute name=\"it_ticketcreatedby\" /&gt;\n    &lt;filter type=\"and\"&gt;\n      &lt;condition attribute=\"statecode\" operator=\"eq\" value=\"0\" /&gt;\n      &lt;condition attribute=\"it_requeststatus\" operator=\"eq\" value=\"0\" /&gt;\n    &lt;/filter&gt;\n  &lt;/entity&gt;\n&lt;/fetch&gt;\n{% endfetchxml %}\n\n&lt;div class=\"hero hero--manager\" style=\"padding:16px 16px 14px\"&gt;\n  &lt;p class=\"hero-eyebrow hero-eyebrow--manager\"&gt;IT Manager view&lt;/p&gt;\n  &lt;h1&gt;Manager dashboard&lt;/h1&gt;\n&lt;/div&gt;\n\n&lt;div class=\"page-wrapper\" id=\"pageWrapper\"&gt;\n  &lt;main class=\"main\"&gt;\n    &lt;div class=\"metric-grid\"&gt;\n      &lt;div class=\"metric-card\"&gt;\n        &lt;p class=\"metric-label\"&gt;Total this month&lt;/p&gt;\n        &lt;p class=\"metric-value\"&gt;{{ alltickets.results.entities.size }}&lt;/p&gt;\n        &lt;p class=\"metric-sub\"&gt;+12 vs last month&lt;/p&gt;\n      &lt;/div&gt;\n      &lt;div class=\"metric-card\"&gt;\n        &lt;p class=\"metric-label\"&gt;In Progress tickets&lt;/p&gt;\n        &lt;p class=\"metric-value metric-value--warn\"&gt;{{ inprogresstickets.results.entities.size }}&lt;/p&gt;\n        &lt;p class=\"metric-sub\"&gt;7 unassigned&lt;/p&gt;\n      &lt;/div&gt;\n      &lt;div class=\"metric-card\"&gt;\n        &lt;p class=\"metric-label\"&gt;Resolved today&lt;/p&gt;\n        &lt;p class=\"metric-value metric-value--success\"&gt;{{ resolvedtickets.results.entities.size }}&lt;/p&gt;\n        &lt;p class=\"metric-sub\"&gt;Avg. 3.2h resolution&lt;/p&gt;\n      &lt;/div&gt;\n      &lt;div class=\"metric-card\"&gt;\n        &lt;p class=\"metric-label\"&gt;Satisfaction score&lt;/p&gt;\n        &lt;p class=\"metric-value\"&gt;4.8&lt;/p&gt;\n        &lt;p class=\"metric-sub\"&gt;Out of 5.0&lt;/p&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=\"two-col\"&gt;\n      &lt;div class=\"card\" style=\"margin-bottom:14px\"&gt;\n        &lt;div class=\"card-head\"&gt;\n          &lt;h3&gt;Agent workload&lt;/h3&gt;\n          &lt;a href=\"#\" class=\"card-link\" style=\"color:#7c3aed\"&gt;Manage →&lt;/a&gt;\n        &lt;/div&gt;\n        &lt;table&gt;\n          &lt;thead&gt;\n            &lt;tr&gt;\n              &lt;th&gt;Agent&lt;/th&gt;\n              &lt;th style=\"text-align:center\"&gt;Open&lt;/th&gt;\n              &lt;th style=\"text-align:center\"&gt;Resolved&lt;/th&gt;\n              &lt;th style=\"width:110px\"&gt;Load&lt;/th&gt;\n            &lt;/tr&gt;\n          &lt;/thead&gt;\n          &lt;tbody&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Mark Davis&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;&lt;span class=\"badge badge--med\"&gt;5&lt;/span&gt;&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;34&lt;/td&gt;\n              &lt;td&gt;\n                &lt;div class=\"bar-wrap\"&gt;\n                  &lt;div class=\"bar-bg\"&gt;\n                    &lt;div class=\"bar-fill bar-fill--medium\" style=\"width:55%\"&gt;&lt;/div&gt;\n                  &lt;/div&gt;\n                  &lt;span class=\"bar-pct\"&gt;55%&lt;/span&gt;\n                &lt;/div&gt;\n              &lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Sarah Wong&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;&lt;span class=\"badge badge--high\"&gt;8&lt;/span&gt;&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;28&lt;/td&gt;\n              &lt;td&gt;\n                &lt;div class=\"bar-wrap\"&gt;\n                  &lt;div class=\"bar-bg\"&gt;\n                    &lt;div class=\"bar-fill bar-fill--high\" style=\"width:80%\"&gt;&lt;/div&gt;\n                  &lt;/div&gt;\n                  &lt;span class=\"bar-pct\"&gt;80%&lt;/span&gt;\n                &lt;/div&gt;\n              &lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Ali Hassan&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;&lt;span class=\"badge badge--done\"&gt;3&lt;/span&gt;&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;41&lt;/td&gt;\n              &lt;td&gt;\n                &lt;div class=\"bar-wrap\"&gt;\n                  &lt;div class=\"bar-bg\"&gt;\n                    &lt;div class=\"bar-fill bar-fill--low\" style=\"width:30%\"&gt;&lt;/div&gt;\n                  &lt;/div&gt;\n                  &lt;span class=\"bar-pct\"&gt;30%&lt;/span&gt;\n                &lt;/div&gt;\n              &lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr style=\"border-top:0.5px solid #e5e7eb\"&gt;\n              &lt;td class=\"unassigned-text\"&gt;Unassigned&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;&lt;span class=\"badge badge--crit\"&gt;7&lt;/span&gt;&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;—&lt;/td&gt;\n              &lt;td style=\"font-size:10px;color:#dc2626\"&gt;Action needed&lt;/td&gt;\n            &lt;/tr&gt;\n          &lt;/tbody&gt;\n        &lt;/table&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"card\" style=\"margin-bottom:14px\"&gt;\n        &lt;div class=\"card-head\"&gt;\n          &lt;h3&gt;Tickets by category&lt;/h3&gt;\n        &lt;/div&gt;\n        &lt;table&gt;\n          &lt;thead&gt;\n            &lt;tr&gt;\n              &lt;th&gt;Category&lt;/th&gt;\n              &lt;th style=\"text-align:center\"&gt;Open&lt;/th&gt;\n              &lt;th style=\"text-align:center\"&gt;Total&lt;/th&gt;\n              &lt;th&gt;Avg time&lt;/th&gt;\n            &lt;/tr&gt;\n          &lt;/thead&gt;\n          &lt;tbody&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Software&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;9&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;52&lt;/td&gt;\n              &lt;td&gt;2.4h&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Hardware&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;6&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;38&lt;/td&gt;\n              &lt;td&gt;4.1h&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Access&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;5&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;31&lt;/td&gt;\n              &lt;td&gt;1.8h&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;Network&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;3&lt;/td&gt;\n              &lt;td style=\"text-align:center\"&gt;21&lt;/td&gt;\n              &lt;td&gt;3.6h&lt;/td&gt;\n            &lt;/tr&gt;\n          &lt;/tbody&gt;\n        &lt;/table&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=\"table-card\"&gt;\n      &lt;div class=\"table-card-head\"&gt;\n        &lt;h3&gt;Full ticket queue&lt;/h3&gt;\n        &lt;a href=\"#\" class=\"card-link\" style=\"color:#7c3aed\"&gt;Export CSV →&lt;/a&gt;\n      &lt;/div&gt;\n      &lt;div class=\"table-wrap\"&gt;\n        &lt;table&gt;\n          &lt;colgroup&gt;\n            &lt;col style=\"width:70px\" /&gt;\n            &lt;col style=\"width:180px\" /&gt;\n            &lt;col style=\"width:70px\" /&gt;\n            &lt;col style=\"width:65px\" /&gt;\n            &lt;col style=\"width:75px\" /&gt;\n            &lt;col style=\"width:85px\" /&gt;\n            &lt;col style=\"width:55px\" /&gt;\n          &lt;/colgroup&gt;\n          &lt;thead&gt;\n            &lt;tr&gt;\n              &lt;th&gt;ID&lt;/th&gt;\n              &lt;th&gt;Title&lt;/th&gt;\n              &lt;th&gt;Employee&lt;/th&gt;\n              &lt;th&gt;Priority&lt;/th&gt;\n              &lt;th&gt;Status&lt;/th&gt;\n              &lt;th&gt;Agent&lt;/th&gt;\n              &lt;th&gt;&lt;/th&gt;\n            &lt;/tr&gt;\n          &lt;/thead&gt;\n          &lt;tbody id=\"tbody\"&gt;\n            &lt;!-- &lt;tr&gt;\n              &lt;td&gt;TKT-0042&lt;/td&gt;\n              &lt;td&gt;Email password expired&lt;/td&gt;\n              &lt;td&gt;S. Patel&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--crit\"&gt;Critical&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--new\"&gt;New&lt;/span&gt;&lt;/td&gt;\n              &lt;td class=\"unassigned-text\"&gt;Unassigned&lt;/td&gt;\n              &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;TKT-0041&lt;/td&gt;\n              &lt;td&gt;Laptop screen flickering&lt;/td&gt;\n              &lt;td&gt;J. Smith&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--med\"&gt;Medium&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--prog\"&gt;In progress&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;M. Davis&lt;/td&gt;\n              &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;TKT-0040&lt;/td&gt;\n              &lt;td&gt;Teams camera not working&lt;/td&gt;\n              &lt;td&gt;L. Chen&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--med\"&gt;Medium&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--new\"&gt;New&lt;/span&gt;&lt;/td&gt;\n              &lt;td class=\"unassigned-text\"&gt;Unassigned&lt;/td&gt;\n              &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;TKT-0039&lt;/td&gt;\n              &lt;td&gt;Cannot access Finance drive&lt;/td&gt;\n              &lt;td&gt;J. Smith&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--high\"&gt;High&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--new\"&gt;New&lt;/span&gt;&lt;/td&gt;\n              &lt;td class=\"unassigned-text\"&gt;Unassigned&lt;/td&gt;\n              &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n              &lt;td&gt;TKT-0038&lt;/td&gt;\n              &lt;td&gt;Printer offline on floor 2&lt;/td&gt;\n              &lt;td&gt;R. Ahmed&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--low\"&gt;Low&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;&lt;span class=\"badge badge--hold\"&gt;On hold&lt;/span&gt;&lt;/td&gt;\n              &lt;td&gt;M. Davis&lt;/td&gt;\n              &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n            &lt;/tr&gt; --&gt;\n          &lt;/tbody&gt;\n        &lt;/table&gt;\n      &lt;/div&gt;\n      &lt;div class=\"table-footer\"&gt;\n        &lt;span class=\"pagination-info\" id=\"paginationInfo\"&gt;&lt;/span&gt;\n        &lt;nav class=\"pagination\" id=\"pagination\" aria-label=\"Ticket pages\"&gt;&lt;/nav&gt;\n      &lt;/div&gt;\n    &lt;/div&gt;\n  &lt;/main&gt;\n&lt;/div&gt;\n&lt;script&gt;\n    var alltickets = [];\n  // var filteredTickets = [];\n\n   {%if alltickets.results.entities | size &gt; 0 %}\n   console.log('size: ', `{{ alltickets.results.entities.size }}`)\n   {% for ticket in alltickets.results.entities %}\n\n   alltickets.push({\n     \"id\": `{{ticket.it_newcolumn}}`,\n     \"title\": `{{ticket.it_tickettitle}}`,\n     \"category\": `{{ticket.it_category.label}}`,\n     \"priority\": `{{ticket.it_priority.label}}`,\n     \"status\": `{{ticket.it_requeststatus.label}}`,\n     \"effectivedate\": `{{ticket.it_startdate | date: \"%d/%M/%y\" }}`,\n     \"reqguid\": `{{ticket.it_requestid}}`\n   })\n\n   {% endfor %}\n   {% endif %}\n   console.log('tickets : ', alltickets)\n\n   var PER_PAGE = 3;   /* rows per page — adjust as needed */\n   var cur = 1;\n   var totalPg = Math.ceil(alltickets.length / PER_PAGE);\n\n   /* ── Sliding window: always exactly 3 page numbers ── */\n   function getWindow() {\n     var s = cur - 1;\n     if (s &lt; 1) s = 1;\n     if (s + 2 &gt; totalPg) s = Math.max(1, totalPg - 2);\n     var win = [];\n     for (var p = s; p &lt;= s + 2 &amp;&amp; p &lt;= totalPg; p++) win.push(p);\n     console.log('win', win)\n     return win;\n   }\n\n   function renderTable(tickets) {\n     var priorityLabel, statusLabel;\n     var start = (cur - 1) * PER_PAGE;\n     var rows = tickets.slice(start, start + PER_PAGE);\n     var html = '';\n     for (var i = 0; i &lt; rows.length; i++) {\n       var t = rows[i];\n       if (t.priority == \"Low\") {\n         priorityLabel = \"low\"\n       }\n       else if (t.priority == \"Medium\") {\n         priorityLabel = \"med\"\n       }\n       else if (t.priority == \"High\") {\n         priorityLabel = \"high\"\n       }\n       else if (t.priority == \"Critical\") {\n         priorityLabel = \"crit\"\n       };\n\n       if (t.status == \"Resolved\") {\n         statusLabel = \"done\"\n       }\n       else if (t.status == \"In Progresss\" || t.status == \"New\") {\n         statusLabel = \"prog\"\n       }\n\n       html += `&lt;tr&gt;\n             &lt;td&gt;${t.id}&lt;/td&gt;\n             &lt;td&gt;${t.title}&lt;/td&gt;\n             &lt;td&gt;S. Patel&lt;/td&gt;\n             &lt;td&gt;&lt;span class=\"badge badge--${priorityLabel}\"&gt;${t.priority}&lt;/span&gt;&lt;/td&gt;\n             &lt;td&gt;&lt;span class=\"badge badge--${t.statusLabel}\"&gt;${t.status}&lt;/span&gt;&lt;/td&gt;\n             &lt;td class=\"unassigned-text\"&gt;Unassigned&lt;/td&gt;\n             &lt;td&gt;&lt;button class=\"tbl-btn tbl-btn--edit\" style=\"color:#7c3aed\"&gt;Edit →&lt;/button&gt;&lt;/td&gt;\n           &lt;/tr&gt;`\n     }\n     document.getElementById('tbody').innerHTML = html;\n     var end = Math.min(start + PER_PAGE, tickets.length);\n     document.getElementById('paginationInfo').textContent =\n       'Showing ' + (start + 1) + '\\u2013' + end + ' of ' + tickets.length + ' tickets';\n   }\n\n   function renderPagination() {\n     var win = getWindow();\n     var html = '';\n\n     /* Prev button */\n     html += '&lt;button id=\"prevBtn\" class=\"page-btn page-btn--nav\"' +\n       (cur === 1 ? ' disabled' : '') + ' aria-label=\"Previous page\"&gt;' +\n       '&lt;svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"' +\n       ' stroke-linecap=\"round\" stroke-linejoin=\"round\"&gt;&lt;polyline points=\"10,3 6,8 10,13\"/&gt;&lt;/svg&gt;' +\n       '&lt;/button&gt;';\n\n     /* 3 page number buttons */\n     for (var i = 0; i &lt; win.length; i++) {\n       var p = win[i];\n       html += `&lt;button id=\"pageBtn_${i + 1}\" class=\"page-btn${p === cur ? ' active' : ''}\"${p === cur ? ' aria-current=\"page\"' : ''}&gt;${p}&lt;/button&gt;`;\n     }\n\n     /* Next button */\n     html += '&lt;button id=\"nextBtn\" class=\"page-btn page-btn--nav\"' +\n       (cur === totalPg ? ' disabled' : '') + ' aria-label=\"Next page\"&gt;' +\n       '&lt;svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"' +\n       ' stroke-linecap=\"round\" stroke-linejoin=\"round\"&gt;&lt;polyline points=\"6,3 10,8 6,13\"/&gt;&lt;/svg&gt;' +\n       '&lt;/button&gt;';\n\n     document.getElementById('pagination').innerHTML = html;\n   }\n\n   function go(p) {\n     if (p &lt; 1 || p &gt; totalPg) return;\n     cur = p;\n\n     //const value = document.getElementById(\"searchbox\").value.trim().toLowerCase();\n\n       renderTable(alltickets);\n\n\n\n\n     renderPagination();\n   }\n\n   /* ── Init ── */\n   renderTable(alltickets);\n   renderPagination();\n\n\n   document.getElementById(\"pagination\").addEventListener(\"click\", function (e) {\n\n     const btn = e.target.closest(\"button\");\n     if (!btn) return;\n\n     if (btn.id === \"prevBtn\" &amp;&amp; cur &gt; 1) {\n       go(cur - 1);\n     }\n\n     else if (btn.id === \"nextBtn\" &amp;&amp; cur &lt; totalPg) {\n       go(cur + 1);\n     }\n\n     else if (btn.id.startsWith(\"pageBtn_\")) {\n       const page = parseInt(btn.id.split(\"_\")[1]);\n       console.log('page:', page)\n       go(page);\n     }\n\n   });\n\n   // document.getElementById(\"searchbox\").addEventListener(\"change\", function () {\n   //   const value = this.value.trim().toLowerCase();\n\n   //   if (value === \"\") {\n   //     filteredTickets = tickets; // reset\n   //   } else {\n   //     filteredTickets = tickets.filter(t =&gt;\n   //       (t.title || \"\").toLowerCase().includes(value) ||\n   //       (t.category || \"\").toLowerCase().includes(value) ||\n   //       (t.priority || \"\").toLowerCase().includes(value) ||\n   //       (t.status || \"\").toLowerCase().includes(value) ||\n   //       (t.id || \"\").toLowerCase().includes(value)\n   //     );\n   //   }\n\n   //   cur = 1;\n   //   totalPg = Math.ceil(filteredTickets.length / PER_PAGE);\n   //   console.log('filtered', filteredTickets)\n\n   //   renderTable(filteredTickets);\n   //   renderPagination();\n   // });\n&lt;/script&gt;\n&lt;div class=\"row sectionBlockLayout text-start\" style=\"display: flex; flex-wrap: wrap; margin: 0px; min-height: auto; padding: 8px;\"&gt;\n  &lt;div class=\"container\" style=\"padding: 0px; display: flex; flex-wrap: wrap;\"&gt;&lt;div class=\"col-lg-12 columnBlockLayout\" style=\"flex-grow: 1; display: flex; flex-direction: column; min-width: 250px;\"&gt;&lt;/div&gt;&lt;/div&gt;\n&lt;/div&gt;\n"
}</content>
