<powerpagecomponent powerpagecomponentid="1404e060-6823-f111-8342-000d3ab2c460">
  <content>{
  "source": "&lt;div class=\"hero hero--login\"&gt;\r\n    &lt;p class=\"hero-eyebrow hero-eyebrow--employee\"&gt;Employee IT Support Portal&lt;/p&gt;\r\n    &lt;h1&gt;Welcome — please sign in&lt;/h1&gt;\r\n    &lt;p&gt;Submit tickets, track issues and find answers in the knowledge base.&lt;/p&gt;\r\n&lt;/div&gt;\r\n&lt;div id=\"login-error\" style=\"\r\n  display: none;\r\n  width: 100%;\r\n  max-width: 420px;\r\n  margin: 0 auto 16px auto;\r\n  padding: 12px 14px;\r\n  border-radius: 8px;\r\n  background-color: #fee2e2;\r\n  border: 1px solid #fecaca;\r\n  color: #991b1b;\r\n  font-size: 12px;\r\n  font-weight: 500;\r\n\"&gt;\r\n&lt;/div&gt;\r\n&lt;div class=\"login-body\"&gt;\r\n    &lt;div class=\"tab-row\"&gt;&lt;button onclick=\"showTab('login',this)\" class=\"tab-btn active\"&gt;Login&lt;/button&gt;&lt;button\r\n            onclick=\"showTab('register',this)\" class=\"tab-btn\"&gt;Register&lt;/button&gt;&lt;/div&gt;\r\n    &lt;!-- LOGIN VIEW --&gt;\r\n    &lt;div id=\"login-view\"&gt;\r\n        &lt;div class=\"login-card\"&gt;\r\n            &lt;div class=\"login-card-header\"&gt;\r\n                &lt;h3&gt;Sign in to your account&lt;/h3&gt;\r\n                &lt;p&gt;Use your company email to access the portal&lt;/p&gt;\r\n            &lt;/div&gt;\r\n            &lt;p class=\"section-label\"&gt;Company SSO&lt;/p&gt;\r\n            &lt;button type=\"button\" class=\"sso-btn\"&gt;\r\n                &lt;svg viewBox=\"0 0 16 16\" fill=\"none\" class=\"sso-icon\"&gt;\r\n                    &lt;rect width=\"16\" height=\"16\" rx=\"3\" fill=\"#0078D4\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"2\" y=\"2\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"8.5\" y=\"2\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"2\" y=\"8.5\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"8.5\" y=\"8.5\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                &lt;/svg&gt;\r\n                Continue with Microsoft Azure AD\r\n            &lt;/button&gt;\r\n            &lt;div class=\"divider-row\"&gt;\r\n                &lt;div class=\"divider-line\"&gt;&lt;/div&gt;\r\n                &lt;span class=\"divider-text\"&gt;or sign in with email&lt;/span&gt;\r\n                &lt;div class=\"divider-line\"&gt;&lt;/div&gt;\r\n            &lt;/div&gt;\r\n            &lt;form onsubmit=\"return false;\" class=\"login-form\"&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"login-email\"&gt;Work Email&lt;/label&gt;&lt;input type=\"email\" id=\"login-email\"\r\n                        placeholder=\"you@company.com\" autocomplete=\"email\" required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"login-password\"&gt;Password&lt;/label&gt;&lt;input type=\"password\"\r\n                        id=\"login-password\" placeholder=\"Enter your password\" autocomplete=\"current-password\"\r\n                        required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;p class=\"forgot-link\"&gt;Forgot password?&lt;/p&gt;\r\n                &lt;button type=\"submit\" class=\"primary-btn\"&gt;Sign in&lt;/button&gt;\r\n            &lt;/form&gt;\r\n            &lt;p class=\"footnote\"&gt;Don't have an account? &lt;a href=\"#\" onclick=\"switchToRegister();return false;\"&gt;Register\r\n                    here&lt;/a&gt;&lt;/p&gt;\r\n        &lt;/div&gt;\r\n    &lt;/div&gt;\r\n    &lt;!-- REGISTER VIEW --&gt;\r\n    &lt;div id=\"register-view\" style=\"display: none;\"&gt;\r\n        &lt;div class=\"login-card\"&gt;\r\n            &lt;div class=\"login-card-header\"&gt;\r\n                &lt;h3&gt;Create your account&lt;/h3&gt;\r\n                &lt;p&gt;Register with your company email to get started&lt;/p&gt;\r\n            &lt;/div&gt;\r\n            &lt;div class=\"step-pills\"&gt;&lt;span class=\"step-pill active\"&gt;1 Account info&lt;/span&gt;&lt;span class=\"step-pill\"&gt;2 Work\r\n                    details&lt;/span&gt;&lt;span class=\"step-pill\"&gt;3 Confirm&lt;/span&gt;&lt;/div&gt;\r\n            &lt;form onsubmit=\"return false;\" class=\"login-form\"&gt;\r\n                &lt;div class=\"field-row\"&gt;\r\n                    &lt;div class=\"form-group\"&gt;&lt;label for=\"reg-first\"&gt;First name&lt;/label&gt;&lt;input type=\"text\" id=\"reg-first\"\r\n                            placeholder=\"John\" autocomplete=\"given-name\" required=\"\" /&gt;&lt;/div&gt;\r\n                    &lt;div class=\"form-group\"&gt;&lt;label for=\"reg-last\"&gt;Last name&lt;/label&gt;&lt;input type=\"text\" id=\"reg-last\"\r\n                            placeholder=\"Smith\" autocomplete=\"family-name\" required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;\r\n                    &lt;label for=\"reg-email\"&gt;Work email&lt;/label&gt;&lt;input type=\"email\" id=\"reg-email\"\r\n                        placeholder=\"john.smith@company.com\" autocomplete=\"email\" required=\"\" /&gt;\r\n                    &lt;p class=\"form-hint\"&gt;Must be a company email address&lt;/p&gt;\r\n                &lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;\r\n                    &lt;label for=\"reg-dept\"&gt;Department&lt;/label&gt;&lt;select id=\"reg-dept\" required=\"\"&gt;\r\n                        &lt;option value=\"\" disabled=\"\" selected=\"\"&gt;Select your department&lt;/option&gt;\r\n                        &lt;option&gt;Finance&lt;/option&gt;\r\n                        &lt;option&gt;Human Resources&lt;/option&gt;\r\n                        &lt;option&gt;Engineering&lt;/option&gt;\r\n                        &lt;option&gt;Marketing&lt;/option&gt;\r\n                        &lt;option&gt;Operations&lt;/option&gt;\r\n                        &lt;option&gt;Sales&lt;/option&gt;\r\n                    &lt;/select&gt;\r\n                &lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"reg-pass\"&gt;Password&lt;/label&gt;&lt;input type=\"password\" id=\"reg-pass\"\r\n                        placeholder=\"Min. 8 characters\" autocomplete=\"new-password\" required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"reg-confirm\"&gt;Confirm password&lt;/label&gt;&lt;input type=\"password\"\r\n                        id=\"reg-confirm\" placeholder=\"Re-enter password\" autocomplete=\"new-password\" required=\"\" /&gt;\r\n                &lt;/div&gt;\r\n                &lt;div class=\"checkbox-row\"&gt;\r\n                    &lt;input type=\"checkbox\" id=\"terms\" required=\"\" /&gt;&lt;span&gt;I agree to the &lt;a href=\"#\"&gt;Terms of Use&lt;/a&gt;\r\n                        and &lt;a href=\"#\"&gt;Privacy Policy&lt;/a&gt;&lt;/span&gt;\r\n                &lt;/div&gt;\r\n                &lt;button type=\"submit\" class=\"primary-btn\"&gt;Create Account&lt;/button&gt;\r\n            &lt;/form&gt;\r\n            &lt;p class=\"footnote\"&gt;Already registered? &lt;a href=\"#\" onclick=\"switchToLogin();return false;\"&gt;Sign in here&lt;/a&gt;\r\n            &lt;/p&gt;\r\n        &lt;/div&gt;\r\n    &lt;/div&gt;\r\n&lt;/div&gt;\r\n&lt;div class=\"row sectionBlockLayout text-start\"\r\n    style=\"display: flex; flex-wrap: wrap; margin: 0px; min-height: auto; padding: 8px;\"&gt;\r\n    &lt;div class=\"container\" style=\"padding: 0px; display: flex; flex-wrap: wrap;\"&gt;\r\n        &lt;div class=\"col-lg-12 columnBlockLayout\"\r\n            style=\"flex-grow: 1; display: flex; flex-direction: column; min-width: 250px;\"&gt;&lt;/div&gt;\r\n    &lt;/div&gt;\r\n&lt;/div&gt;\r\n\r\n&lt;script&gt;\r\n    function showTab(tab, btn) {\r\n        document.querySelectorAll('.tab-btn').forEach(b =&gt; b.classList.remove('active'));\r\n        btn.classList.add('active');\r\n        document.getElementById('login-view').style.display = tab === 'login' ? 'block' : 'none';\r\n        document.getElementById('register-view').style.display = tab === 'register' ? 'block' : 'none';\r\n    }\r\n    function switchToRegister() { showTab('register', document.querySelectorAll('.tab-btn')[1]); }\r\n    function switchToLogin() { showTab('login', document.querySelectorAll('.tab-btn')[0]); }\r\n\r\n    $(document).ready(function(){\r\n        $('#login-email').on('input', function(){\r\n            $('#Username').val($(this).val());\r\n        });\r\n         $('#login-password').on('input', function(){\r\n            $('#PasswordValue').val($(this).val());\r\n        });\r\n        $(\".primary-btn\").on(\"click\", function (e) {\r\n      e.preventDefault(); // stop default submit\r\n      $(\"#submit-signin-local\").click(); // trigger actual button\r\n    });\r\n    var errorText = $(\".validation-summary-errors li, .alert-danger\").text();\r\n\r\n  if (errorText.trim() !== \"\") {\r\n    console.log('*',errorText)\r\n    $(\"#login-error\").text(errorText).show();\r\n  }\r\n    })\r\n&lt;/script&gt;"
}</content>
