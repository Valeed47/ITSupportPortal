<powerpagecomponent powerpagecomponentid="2fb5d5a4-6723-f111-8342-000d3ab2c460">
  <content>{
  "type": 756150001,
  "value": "&lt;div class=\"hero hero--login\"&gt;\r\n    &lt;p class=\"hero-eyebrow hero-eyebrow--employee\"&gt;Employee IT Support Portal&lt;/p&gt;\r\n    &lt;h1&gt;Welcome — please sign in&lt;/h1&gt;\r\n    &lt;p&gt;Submit tickets, track issues and find answers in the knowledge base.&lt;/p&gt;\r\n&lt;/div&gt;\r\n&lt;div id=\"login-error\" style=\"\r\n  display: none;\r\n  width: 100%;\r\n  max-width: 420px;\r\n  margin: 0 auto 16px auto;\r\n  padding: 12px 14px;\r\n  border-radius: 8px;\r\n  background-color: #fee2e2;\r\n  border: 1px solid #fecaca;\r\n  color: #991b1b;\r\n  font-size: 12px;\r\n  font-weight: 500;\r\n\"&gt;\r\n&lt;/div&gt;\r\n&lt;div class=\"login-body\"&gt;\r\n    &lt;!-- &lt;div class=\"tab-row\"&gt;&lt;button onclick=\"showTab('login',this)\" class=\"tab-btn active\"&gt;Login&lt;/button&gt;\r\n        &lt;button\r\n            onclick=\"showTab('register',this)\" class=\"tab-btn\"&gt;Register&lt;/button&gt;\r\n        &lt;/div&gt; --&gt;\r\n    &lt;!-- LOGIN VIEW --&gt;\r\n    &lt;div id=\"login-view\"&gt;\r\n        &lt;div class=\"login-card\"&gt;\r\n            &lt;div class=\"login-card-header\"&gt;\r\n                &lt;h3&gt;Sign in to your account&lt;/h3&gt;\r\n                &lt;p&gt;Use your company email to access the portal&lt;/p&gt;\r\n            &lt;/div&gt;\r\n            &lt;p class=\"section-label\"&gt;Company SSO&lt;/p&gt;\r\n            &lt;button type=\"button\" class=\"sso-btn\"&gt;\r\n                &lt;svg viewBox=\"0 0 16 16\" fill=\"none\" class=\"sso-icon\"&gt;\r\n                    &lt;rect width=\"16\" height=\"16\" rx=\"3\" fill=\"#0078D4\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"2\" y=\"2\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"8.5\" y=\"2\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"2\" y=\"8.5\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                    &lt;rect x=\"8.5\" y=\"8.5\" width=\"5.5\" height=\"5.5\" rx=\"1\" fill=\"white\" opacity=\".9\"&gt;&lt;/rect&gt;\r\n                &lt;/svg&gt;\r\n                Continue with Microsoft Azure AD\r\n            &lt;/button&gt;\r\n            &lt;div class=\"divider-row\"&gt;\r\n                &lt;div class=\"divider-line\"&gt;&lt;/div&gt;\r\n                &lt;span class=\"divider-text\"&gt;or sign in with email&lt;/span&gt;\r\n                &lt;div class=\"divider-line\"&gt;&lt;/div&gt;\r\n            &lt;/div&gt;\r\n            &lt;form onsubmit=\"return false;\" class=\"login-form\"&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"login-email\"&gt;Work Email&lt;/label&gt;&lt;input type=\"email\" id=\"login-email\"\r\n                        placeholder=\"you@company.com\" autocomplete=\"email\" required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;div class=\"form-group\"&gt;&lt;label for=\"login-password\"&gt;Password&lt;/label&gt;&lt;input type=\"password\"\r\n                        id=\"login-password\" placeholder=\"Enter your password\" autocomplete=\"current-password\"\r\n                        required=\"\" /&gt;&lt;/div&gt;\r\n                &lt;p class=\"forgot-link\"&gt;Forgot password?&lt;/p&gt;\r\n                &lt;button type=\"submit\" class=\"primary-btn\"&gt;Sign in&lt;/button&gt;\r\n            &lt;/form&gt;\r\n            &lt;p class=\"footnote\"&gt;Don't have an account? &lt;a href=\"/Account/Login/Register\"&gt;Register\r\n                    here&lt;/a&gt;&lt;/p&gt;\r\n        &lt;/div&gt;\r\n    &lt;/div&gt;\r\n    &lt;!-- REGISTER VIEW --&gt;\r\n    &lt;div id=\"register-view\" style=\"display: none;\"&gt;\r\n        &lt;div class=\"login-card\"\r\n            style=\"max-width:400px; margin:auto; padding:20px; border:1px solid #ccc; border-radius:8px;\"&gt;\r\n            &lt;div class=\"login-card-header\" style=\"text-align:center; margin-bottom:20px;\"&gt;\r\n                &lt;h3&gt;Create your account&lt;/h3&gt;\r\n                &lt;p&gt;Register to get started&lt;/p&gt;\r\n            &lt;/div&gt;\r\n            &lt;form onsubmit=\"return false;\" class=\"login-form\"&gt;\r\n\r\n                &lt;!-- Email --&gt;\r\n                &lt;div class=\"form-group\" style=\"margin-bottom:15px;\"&gt;\r\n                    &lt;label for=\"reg-email\"&gt;Email&lt;/label&gt;\r\n                    &lt;input type=\"email\" id=\"reg-email\" placeholder=\"john.smith@company.com\" required\r\n                        style=\"width:100%; padding:8px;\" /&gt;\r\n                &lt;/div&gt;\r\n\r\n                &lt;!-- Username --&gt;\r\n                &lt;div class=\"form-group\" style=\"margin-bottom:15px;\"&gt;\r\n                    &lt;label for=\"reg-username\"&gt;Username&lt;/label&gt;\r\n                    &lt;input type=\"text\" id=\"reg-username\" placeholder=\"Username\" required\r\n                        style=\"width:100%; padding:8px;\" /&gt;\r\n                &lt;/div&gt;\r\n\r\n                &lt;!-- Password --&gt;\r\n                &lt;div class=\"form-group\" style=\"margin-bottom:15px;\"&gt;\r\n                    &lt;label for=\"reg-pass\"&gt;Password&lt;/label&gt;\r\n                    &lt;input type=\"password\" id=\"reg-pass\" placeholder=\"Min. 8 characters\" required\r\n                        style=\"width:100%; padding:8px;\" /&gt;\r\n                &lt;/div&gt;\r\n\r\n                &lt;!-- Confirm Password --&gt;\r\n                &lt;div class=\"form-group\" style=\"margin-bottom:15px;\"&gt;\r\n                    &lt;label for=\"reg-confirm\"&gt;Confirm Password&lt;/label&gt;\r\n                    &lt;input type=\"password\" id=\"reg-confirm\" placeholder=\"Re-enter password\" required\r\n                        style=\"width:100%; padding:8px;\" /&gt;\r\n                &lt;/div&gt;\r\n\r\n                &lt;!-- Captcha Image --&gt;\r\n                &lt;div class=\"form-group\" style=\"margin-bottom:15px; text-align:center;\"&gt;\r\n                    &lt;label for=\"captcha\"&gt;Captcha&lt;/label&gt;&lt;br&gt;\r\n                    &lt;img src=\"captcha_image_url_here\" alt=\"Captcha\" style=\"margin:10px 0; border:1px solid #ccc;\" /&gt;&lt;br&gt;\r\n                    &lt;input type=\"text\" id=\"captcha-code\" placeholder=\"Enter code from image\" required\r\n                        style=\"width:100%; padding:8px;\" /&gt;\r\n                &lt;/div&gt;\r\n\r\n                &lt;!-- Register Button --&gt;\r\n                &lt;button type=\"submit\" class=\"primary-btn\" id=\"rgstrBtn\"\r\n                    style=\"width:100%; padding:10px; background:#0078D4; color:white; border:none; border-radius:4px; cursor:pointer;\"&gt;\r\n                    Register\r\n                &lt;/button&gt;\r\n            &lt;/form&gt;\r\n        &lt;/div&gt;\r\n    &lt;/div&gt;\r\n&lt;/div&gt;\r\n&lt;div class=\"row sectionBlockLayout text-start\"\r\n    style=\"display: flex; flex-wrap: wrap; margin: 0px; min-height: auto; padding: 8px;\"&gt;\r\n    &lt;div class=\"container\" style=\"padding: 0px; display: flex; flex-wrap: wrap;\"&gt;\r\n        &lt;div class=\"col-lg-12 columnBlockLayout\"\r\n            style=\"flex-grow: 1; display: flex; flex-direction: column; min-width: 250px;\"&gt;&lt;/div&gt;\r\n    &lt;/div&gt;\r\n&lt;/div&gt;\r\n&lt;footer class=\"site-footer site-footer--employee\"&gt;\r\n    &lt;p class=\"footer-copy--employee\"&gt;IT Support Portal &amp;copy; 2025 &amp;mdash; Powered by Microsoft Power Pages&lt;/p&gt;\r\n    &lt;div class=\"footer-links footer-links--employee\"&gt;\r\n        &lt;a href=\"#\"&gt;ext. 1234&lt;/a&gt;\r\n        &lt;a href=\"#\"&gt;Email IT&lt;/a&gt;\r\n        &lt;a href=\"#\"&gt;Privacy&lt;/a&gt;\r\n    &lt;/div&gt;\r\n&lt;/footer&gt;\r\n\r\n&lt;script&gt;\r\n    $(document).ready(function () {\r\n        $(\"ul.nav-account\").hide();\r\n        $(\".row &gt; .col-md-6\").hide();\r\n        document.getElementById(\"mainContent\").style.marginTop = \"0px\";\r\n        $(\".login-card\").css({\r\n            \"max-width\": \"100%\",\r\n            \"margin-left\": \"0\",\r\n            \"margin-right\": \"0\"\r\n        });\r\n        $('#login-email').on('input', function () {\r\n            $('#Username').val($(this).val());\r\n        });\r\n        $('#login-password').on('input', function () {\r\n            $('#PasswordValue').val($(this).val());\r\n        });\r\n        $(\".primary-btn\").on(\"click\", function (e) {\r\n            e.preventDefault(); // stop default submit\r\n            $(\"#submit-signin-local\").click(); // trigger actual button\r\n        });\r\n        $('.sso-btn').click(function () {\r\n            $('#https\\\\:\\\\/\\\\/login\\\\.windows\\\\.net\\\\/b28b41db\\\\-d246\\\\-4353\\\\-bd64\\\\-bc6cb4797496\\\\/').click();\r\n        });\r\n\r\n        var errorText = $(\".validation-summary-errors li, .alert-danger\").text();\r\n\r\n        if (errorText.trim() !== \"\") {\r\n            console.log('*', errorText)\r\n            $(\"#login-error\").text(errorText).show();\r\n        }\r\n    })\r\n&lt;/script&gt;"
}</content>
